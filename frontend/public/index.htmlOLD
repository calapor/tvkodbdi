<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My App Hub</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      background-color: #f7f9fc;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 2rem;
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
      color: #333;
    }

    .button-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      max-width: 400px;
    }

    .app-button {
      background-color: #007bff;
      color: white;
      padding: 1.2rem 1rem;
      text-align: center;
      text-decoration: none;
      font-size: 1.2rem;
      border-radius: 8px;
      font-weight: 600;
      transition: background-color 0.3s ease;
    }

    .app-button:hover {
      background-color: #0056b3;
    }

    @media (min-width: 600px) {
      .button-container {
        flex-direction: row;
        flex-wrap: wrap;
        justify-content: center;
      }

      .app-button {
        flex: 1 1 40%;
        margin: 0.5rem;
      }
    }
  </style>
</head>
<body>
  <div class="button-container">
    <a href="/tvkodi.html" class="app-button" target="_blank">TV Kodi Shows</a>

    <!-- Add more app links here -->
  </div>
</body>
</html>
